# Custom OpenClaw agent image with additional CLI tools.
#
# Thin overlay on the upstream image — edit the package list below
# to add or remove tools. The GitHub Action rebuilds automatically
# when this file changes.
#
# Build locally:
#   podman build -t openclaw-agent:dev image/
#
# Pin to a specific upstream release:
#   podman build --build-arg UPSTREAM=ghcr.io/openclaw/openclaw:2026.6.11 \
#     -t openclaw-agent:dev image/

ARG UPSTREAM=ghcr.io/openclaw/openclaw:latest
FROM ${UPSTREAM}

USER 0

# ── Apt packages ──────────────────────────────
# Edit this list to add tools available in Debian Bookworm repos.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    jq unzip \
    && rm -rf /var/lib/apt/lists/*

# ── Static binaries (not in Debian repos) ─────
ARG TARGETARCH=amd64

ARG YQ_VERSION=v4.53.3
ARG YQ_SHA256=fa52a4e758c63d38299163fbdd1edfb4c4963247918bf9c1c5d31d84789eded4
RUN curl -fsSL \
    "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_${TARGETARCH}" \
    -o /usr/local/bin/yq \
    && echo "${YQ_SHA256}  /usr/local/bin/yq" | sha256sum -c - \
    && chmod +x /usr/local/bin/yq

ARG RCLONE_VERSION=v1.74.4
ARG RCLONE_SHA256=fe435e0c36228e7c2f116a8701f01127bb1f694005fc11d1f27186c8bca4115d
RUN curl -fsSL \
    "https://downloads.rclone.org/${RCLONE_VERSION}/rclone-${RCLONE_VERSION}-linux-${TARGETARCH}.zip" \
    -o /tmp/rclone.zip \
    && echo "${RCLONE_SHA256}  /tmp/rclone.zip" | sha256sum -c - \
    && unzip -j /tmp/rclone.zip "*/rclone" -d /usr/local/bin/ \
    && chmod +x /usr/local/bin/rclone \
    && rm /tmp/rclone.zip

# ── Restore non-root user ─────────────────────
# OpenShift overrides this with a namespace-assigned UID,
# but this ensures non-root on vanilla Kubernetes too.
USER 1000
